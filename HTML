<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Luxe Beauty</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
</head>
<body>

    <!-- FIREWORKS -->
    <div class="fireworks">
        <div class="firework"></div>
        <div class="firework"></div>
        <div class="firework"></div>
        <div class="firework"></div>
        <div class="firework"></div>
    </div>

    <!-- NAVBAR -->
    <nav class="navbar">
        <div class="logo">✦ LUXE BEAUTY</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#products">Products</a></li>
            <li><a href="#gallery">Gallery</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
    </nav>

    <!-- HERO -->
    <section class="hero" id="home">
        <div class="hero-overlay"></div>
        <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=1600" 
             alt="hero" class="hero-bg">
        <div class="hero-content">
            <p class="hero-sub">Welcome to Luxe Beauty</p>
            <h1>Redefine Your<br><span>Natural Glow</span></h1>
            <p class="hero-desc">Premium cosmetics crafted with love and nature</p>
            <a href="#products" class="btn">Explore Collection</a>
        </div>
    </section>

    <!-- MARQUEE STRIP -->
    <div class="strip">
        <div class="strip-track">
            <span>✦ FREE SHIPPING</span>
            <span>✦ CRUELTY FREE</span>
            <span>✦ NATURAL INGREDIENTS</span>
            <span>✦ VEGAN FRIENDLY</span>
            <span>✦ DERMATOLOGIST TESTED</span>
            <span>✦ FREE SHIPPING</span>
            <span>✦ CRUELTY FREE</span>
            <span>✦ NATURAL INGREDIENTS</span>
            <span>✦ VEGAN FRIENDLY</span>
            <span>✦ DERMATOLOGIST TESTED</span>
        </div>
    </div>

    <!-- ABOUT -->
    <section class="about" id="about">
        <div class="about-img">
            <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=800" 
                 alt="about">
        </div>
        <div class="about-text">
            <p class="section-label">Our Story</p>
            <h2>Beauty That Comes<br>From Within</h2>
            <p>At Luxe Beauty, we believe that true beauty is rooted in nature. Every product 
            we create is carefully formulated with the finest natural ingredients, 
            free from harmful chemicals, and designed to enhance your unique beauty.</p>
            <p>We are passionate about sustainability, cruelty-free practices, 
            and delivering results that make you feel absolutely radiant.</p>
            <a href="#products" class="btn">Our Products</a>
        </div>
    </section>

    <!-- PRODUCTS -->
    <section class="products" id="products">
        <p class="section-label center">Our Collection</p>
        <h2 class="center">Best Sellers</h2>

        <div class="product-grid">

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1586495777744-4e6232bf2919?w=500" 
                         alt="lipstick">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Velvet Lip Rouge</h3>
                    <p>Rich & long-lasting color</p>
                    <span>$22.99</span>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1512496015851-a90fb38ba796?w=500" 
                         alt="foundation">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Silk Glow Foundation</h3>
                    <p>Flawless & lightweight finish</p>
                    <span>$38.99</span>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1583241475880-083f84372725?w=500" 
                         alt="eyeshadow">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Smoky Eye Palette</h3>
                    <p>12 stunning blendable shades</p>
                    <span>$31.99</span>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1620916566398-39f1143ab7be?w=500" 
                         alt="serum">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Rose Gold Serum</h3>
                    <p>Nourish & hydrate deeply</p>
                    <span>$49.99</span>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1599305090598-fe179d501227?w=500" 
                         alt="blush">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Soft Blush Powder</h3>
                    <p>Natural flush of color</p>
                    <span>$18.99</span>
                </div>
            </div>

            <div class="product-card">
                <div class="product-img-wrap">
                    <img src="https://images.unsplash.com/photo-1598440947619-2c35fc9aa908?w=500" 
                         alt="moisturizer">
                    <div class="overlay-card">
                        <a href="#" class="btn-card">Add to Cart</a>
                    </div>
                </div>
                <div class="product-info">
                    <h3>Petal Soft Moisturizer</h3>
                    <p>24hr hydration & care</p>
                    <span>$26.99</span>
                </div>
            </div>

        </div>
    </section>

    <!-- BANNER -->
    <section class="banner">
        <div class="banner-overlay"></div>
        <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=1600" 
             alt="banner" class="banner-bg">
        <div class="banner-content">
            <h2>Up to 40% Off</h2>
            <p>On selected premium products this season</p>
            <a href="#products" class="btn btn-white">Shop the Sale</a>
        </div>
    </section>

    <!-- GALLERY -->
    <section class="gallery" id="gallery">
        <p class="section-label center">Instagram Vibes</p>
        <h2 class="center">Our Look Book</h2>
        <div class="gallery-grid">
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=500" alt="g1">
                <div class="gallery-hover">✦</div>
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1519415510236-718bdfcd89c8?w=500" alt="g2">
                <div class="gallery-hover">✦</div>
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=500" alt="g3">
                <div class="gallery-hover">✦</div>
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=500" alt="g4">
                <div class="gallery-hover">✦</div>
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9?w=500" alt="g5">
                <div class="gallery-hover">✦</div>
            </div>
            <div class="gallery-item">
                <img src="https://images.unsplash.com/photo-1583241475880-083f84372725?w=500" alt="g6">
                <div class="gallery-hover">✦</div>
            </div>
        </div>
    </section>

    <!-- TESTIMONIALS -->
    <section class="testimonials">
        <p class="section-label center">Reviews</p>
        <h2 class="center">What They Say</h2>
        <div class="testimonial-grid">
            <div class="testimonial-card">
                <p>"I've tried so many brands but Luxe Beauty is on another level. 
                My skin has never looked better!"</p>
                <div class="stars">★★★★★</div>
                <h4>— Sarah M.</h4>
            </div>
            <div class="testimonial-card">
                <p>"The Velvet Lip Rouge stays on all day and the color is absolutely stunning. 
                I'm obsessed!"</p>
                <div class="stars">★★★★★</div>
                <h4>— Layla K.</h4>
            </div>
            <div class="testimonial-card">
                <p>"Finally a brand that cares about natural ingredients without 
                compromising on quality. Love it!"</p>
                <div class="stars">★★★★★</div>
                <h4>— Nora A.</h4>
            </div>
        </div>
    </section>

    <!-- CONTACT -->
    <section class="contact" id="contact">
        <p class="section-label center">Get In Touch</p>
        <h2 class="center">Contact Us</h2>
        <form class="contact-form">
            <div class="form-row">
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
            </div>
            <input type="text" placeholder="Subject">
            <textarea rows="5" placeholder="Your Message" required></textarea>
            <button type="submit" class="btn">Send Message ✦</button>
        </form>
    </section>

    <!-- FOOTER -->
    <footer class="footer">
        <div class="footer-top">
            <div class="footer-brand">
                <h3>✦ LUXE BEAUTY</h3>
                <p>Enhancing your natural beauty<br>with the power of nature.</p>
            </div>
            <div class="footer-links">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="#home">Home</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#products">Products</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer-social">
                <h4>Follow Us</h4>
                <div class="socials">
                    <a href="#">Instagram</a>
                    <a href="#">Facebook</a>
                    <a href="#">TikTok</a>
                    <a href="#">Pinterest</a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>© 2024 Luxe Beauty. All rights reserved. Made with 🌸</p>
        </div>
    </footer>

</body>
</html>
